# Rename this file to ".env" and fill in your real values before running the server.

# Get a free Gemini API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Any long random string. Used to sign login tokens (JWT).
JWT_SECRET_KEY=change_this_to_a_long_random_secret_string

# How long a login session stays valid, in minutes
JWT_EXPIRE_MINUTES=1440

# --- Email alerts for missed deadlines (optional) ---
# Set to true and fill in an SMTP provider (e.g. Gmail app password, SendGrid SMTP relay)
# to also send an email whenever an in-app "missed deadline" notification is created.
EMAIL_ALERTS_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=alerts@yourapp.com

# Base URL used to build the "forgot password" reset link. Change this to your
# real domain in production. If EMAIL_ALERTS_ENABLED is false, the reset link
# is returned directly by the API instead of emailed, so forgot-password still
# works locally without any SMTP setup.
FRONTEND_URL=http://localhost:8000
